@page
@model MonitoringSystem.Pages.DashboardAllBu.IndexModel
@{
    ViewData["Title"] = "Production Management System";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
</head>
<body>

    <header class="main-header">
        <div class="header-logo">
            <img src="~/assets/panasonic_logo.png" alt="Panasonic" style="height:20px; width:auto;" />
        </div>
        <img src="~/assets/Panamon_Logo.png" alt="Panamon" style="
        height: 32px;
        width: auto;
        object-fit: contain;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    " />
        <div style="display:flex; align-items:center; gap:12px;">
            <button onclick="window.location.href='/BusinessUnitReport/Index'" style="
            background: transparent;
            border: 1px solid rgba(255,255,255,0.5);
            border-radius: 20px;
            padding: 4px 14px;
            color: #fff;
            font-size: 0.85rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
        " onmouseover="this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.background='transparent'">
                📊 BU Chart
            </button>
            <button id="theme-toggle" onclick="toggleTheme()" style="
            background: transparent;
            border: 1px solid rgba(255,255,255,0.5);
            border-radius: 20px;
            padding: 4px 14px;
            color: #fff;
            font-size: 0.85rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
        ">
                🌙 Dark
            </button>
            <div id="date-display" class="header-date"></div>
        </div>
    </header>

    <div class="main-content">
        <div class="left-panel">

            <div class="map-wrapper">
                <img src="~/assets/denah_panasonic.png" class="map-image" alt="Map" />
            </div>

            <div class="bottom-row">

                <div class="stat-card bottom-card" onclick="window.open('http://137.40.93.165:5001', 'audio_dashboard')" style="cursor:pointer;">
                    <div class="metric-header">
                        <div id="title_audio" class="card-title">Assembly Achievement</div>
                    </div>
                    <div class="card-subtitle">Audio</div>
                    <div class="slider-viewport">
                        <div id="track_audio" class="slider-track"></div>
                    </div>
                </div>
                
                <div class="stat-card bottom-card">
                    <div class="metric-header">
                        <div id="title_fan" class="card-title">Assembly Achievement</div>
                    </div>
                    <div class="card-subtitle">Fan</div>
                    <div class="slider-viewport">
                        <div id="track_fan" class="slider-track"></div>
                    </div>
                </div>

                <div class="stat-card bottom-card" onclick="window.open('http://10.83.32.31:7189', 'wp_dashboard')" style="cursor:pointer;">
                    <div class="metric-header">
                        <div id="title_wp" class="card-title">Assembly Achievement</div>
                    </div>
                    <div class="card-subtitle">Water Pump</div>
                    <div class="slider-viewport">
                        <div id="track_wp" class="slider-track"></div>
                    </div>
                </div>

            </div>
        </div>

        <div class="right-panel">

            <div class="stat-card" onclick="window.open('http://10.83.33.103:5009', 'ac_dashboard')" style="cursor:pointer;">
                <div class="metric-header">
                    <div id="title_ac" class="card-title">Assembly Achievement</div>
                </div>
                <div class="card-subtitle">Air Conditioner</div>
                <div class="slider-viewport">
                    <div id="track_ac" class="slider-track"></div>
                </div>
            </div>

            <div class="stat-card" onclick="window.open('http://10.83.34.43:8080', 'audio_dashboard')" style="cursor:pointer;">
                <div class="metric-header">
                    <div id="title_ls" class="card-title">Assembly Achievement</div>
                </div>
                <div class="card-subtitle">Laundry</div>
                <div class="slider-viewport">
                    <div id="track_ls" class="slider-track"></div>
                </div>
            </div>

            <!-- SESUDAH (jadi card Refrigerator) -->
            <div class="stat-card">
                <div class="metric-header">
                    <div id="title_ref" class="card-title">Assembly Achievement</div>
                </div>
                <div class="card-subtitle">Refrigerator</div>
                <div class="slider-viewport">
                    <div id="track_ref" class="slider-track"></div>
                </div>
            </div>

        </div>
    </div>

    <script>
        // ═══════════════════════════════════════════════════════
        // 1. CONFIGURATION
        // ═══════════════════════════════════════════════════════
        let charts = {};
        const METRICS = ["Assembly Achievement", "Assembly Quality Defect", "Assembly Loss Time"];
        const TYPES   = ["ach", "qual", "loss"];

        const config = {
            ac:    { lines: 2, labels: ["CU", "CS"],   oneSlide: true  },
            audio: { lines: 1, labels: ["Final"],       oneSlide: true  },
            ls:    { lines: 2, labels: ["2T", "SKD"],   oneSlide: true  },
            fan:   { lines: 1, labels: ["Final"],       oneSlide: true  },
            ref:   { lines: 2, labels: ["REF", "WD"],   oneSlide: true  },
            wp:    { lines: 1, labels: ["Final"],       oneSlide: true  }
        };

        const state = {
            ac:    { page: 0, metricIdx: 0, totalPages: 1 },
            audio: { page: 0, metricIdx: 0, totalPages: 1 },
            ls:    { page: 0, metricIdx: 0, totalPages: 1 },
            fan:   { page: 0, metricIdx: 0, totalPages: 1 },
            ref:   { page: 0, metricIdx: 0, totalPages: 1 },
            wp:    { page: 0, metricIdx: 0, totalPages: 1 }
        };

        // ═══════════════════════════════════════════════════════
        // 2. HTML GENERATORS
        // ═══════════════════════════════════════════════════════

        // A. Achievement (Gauge)
        function createAchHTML(idPrefix, label) {
            return `
            <div class="gauge-container">
                <div style="display:flex; flex-direction:row; align-items:center; width:100%; height:100%;">
                    <div class="canvas-wrapper" style="flex:1; min-width:0; max-width:60%; height:100%; position:relative;">
                        <canvas id="${idPrefix}" style="position:absolute; left:0; top:0; width:100% !important; height:100% !important;"></canvas>
                    </div>
                    <div class="legend-and-total">
                        <div class="legend-row bordered">
                            <span class="legend-dot" style="background:#22C55E; border-color:#22C55E;"></span>
                            <span class="legend-key">Plan</span>
                            <span class="legend-value"><span id="val_${idPrefix}">0</span></span>
                        </div>
                        <div class="legend-row bordered">
                            <span class="legend-dot" style="background:#A855F7; border-color:#A855F7;"></span>
                            <span class="legend-key">Actual</span>
                            <span class="legend-value"><span id="act_${idPrefix}">0</span></span>
                        </div>
                        <div class="legend-row bordered speed-row">
                            <span class="legend-dot" id="sdot_${idPrefix}" style="background:#F59E0B; border-color:#F59E0B;"></span>
                            <span class="legend-key">Speed</span>
                            <span class="legend-value"><span id="spd_${idPrefix}">0</span>%</span>
                        </div>
                        <div class="legend-row total-plan-row">
                            <div class="total-plan-label-row">
                                <span class="legend-dot" style="background:#F59E0B; border-color:#F59E0B;"></span>
                                <span class="legend-key">Total Plan</span>
                            </div>
                            <span class="legend-value"><span id="end_${idPrefix}">0</span></span>
                        </div>
                    </div>
                </div>
            </div>`;
        }

        // B. Quality (Progress Bar)
        function createQualHTML(idPrefix, label) {
            return `
            <div class="quality-container">
                <div class="quality-row">
                    <div class="qual-label"><span>${label}</span></div>
                    <div class="qual-bar-bg">
                        <div id="bar_${idPrefix}" class="qual-bar-fill" style="width:0%">0%</div>
                    </div>
                </div>
            </div>`;
        }

        // C. Loss Time — sama persis struktur WP standalone
        function createLossHTML(idPrefix, label) {
            return `
            <div class="loss-container">
                <div class="loss-line-wrapper">
                    <div style="display:flex; flex-direction:row; align-items:center; gap:10px; flex:1 1 0; min-height:0;">
                        <b class="loss-line-badge">${label}</b>
                        <div class="timeline-container">
                            <div class="timeline-track-wrapper">
                                <div id="timeline-track-${idPrefix}" class="timeline-track">
                                    <div id="timeline-progress-${idPrefix}" class="timeline-progress"></div>
                                </div>
                                <div class="timeline-minutes" id="timeline-minutes-${idPrefix}"></div>
                            </div>
                            <div class="timeline-hours" id="timeline-hours-${idPrefix}"></div>
                        </div>
                    </div>
                    <div class="loss-summary">
                        <div class="loss-summary-item">
                            <span class="loss-legend-dot" style="background:#4F86F3;"></span>
                            <span class="loss-legend-label">Load Time</span>
                            <span id="ld_${idPrefix}" class="loss-legend-value">0</span>
                        </div>
                        <div class="loss-summary-item">
                            <span class="loss-legend-dot" style="background:#d90429;"></span>
                            <span class="loss-legend-label">Loss Time</span>
                            <span id="lt_${idPrefix}" class="loss-legend-value">0</span>
                        </div>
                        <div class="loss-summary-item">
                            <span class="loss-legend-dot" style="visibility:hidden;"></span>
                            <span class="loss-legend-label">Working Time</span>
                            <span id="wt_${idPrefix}" class="loss-legend-value">0</span>
                        </div>
                    </div>
                </div>
            </div>`;
        }

        // ═══════════════════════════════════════════════════════
        // 3. INIT DASHBOARD
        // ═══════════════════════════════════════════════════════
        function initDashboard() {
            Object.keys(config).forEach(key => {
                const conf  = config[key];
                const track = document.getElementById(`track_${key}`);
                if (!track) return;

                track.innerHTML = '';
                const totalPages = conf.oneSlide ? 1 : Math.ceil(conf.lines / 2);
                state[key].totalPages = totalPages;

                for (let p = 0; p < totalPages; p++) {
                    const slideDiv = document.createElement('div');
                    slideDiv.className = 'slide-page';

                    const idx1 = (p * 2) + 1;
                    const idx2 = (p * 2) + 2;

                    TYPES.forEach((type, mIdx) => {
                        const isActive = (mIdx === 0) ? 'active' : '';
                        let layerHTML = `<div class="view-section ${type} ${isActive}">`;

                        const getHTML = (idx, type) => {
                            const lbl = conf.labels.length > 0
                                ? (conf.labels[idx-1] || `Line ${idx}`)
                                : `Line ${idx}`;
                            const uid = `${key}_${idx}_${type}`;
                            if (type === 'ach')  return createAchHTML(uid, lbl);
                            if (type === 'qual') return createQualHTML(uid, lbl);
                            if (type === 'loss') return createLossHTML(uid, lbl);
                        };

                                if (idx1 <= conf.lines) layerHTML += getHTML(idx1, type);

        if (!conf.oneSlide) {
            if (idx2 <= conf.lines) layerHTML += getHTML(idx2, type);
            else layerHTML += `<div style="width:50%;"></div>`;
        } else if (conf.lines === 2) {
            const lbl2 = conf.labels[1];
            const uid2 = `${key}_2_${type}`;
            if (type === 'ach')  layerHTML += createAchHTML(uid2, lbl2);
            if (type === 'qual') layerHTML += createQualHTML(uid2, lbl2);
            if (type === 'loss') layerHTML += createLossHTML(uid2, lbl2);
        } else if (conf.lines === 1 && conf.oneSlide) {
            layerHTML = `<div class="view-section ${type} ${isActive}" style="justify-content:center;">`;
            layerHTML += getHTML(idx1, type);
        }

                        layerHTML += `</div>`;
                        slideDiv.innerHTML += layerHTML;
                    });

                    track.appendChild(slideDiv);
                }

                for (let i = 1; i <= conf.lines; i++) {
                    initChartInstance(`${key}_${i}_ach`);
                }
            });
        }

        // ═══════════════════════════════════════════════════════
        // 4. NAVIGATION
        // ═══════════════════════════════════════════════════════
        window.changeLine = function(key, dir) {
            const st = state[key];
            if (st.totalPages <= 1) return;
            st.page = (st.page + dir + st.totalPages) % st.totalPages;
            const track = document.getElementById(`track_${key}`);
            if (track) track.style.transform = `translateX(-${st.page * 100}%)`;
        };

        window.changeMetric = function(key, dir) {
            const st = state[key];
            const oldIdx = st.metricIdx;
            st.metricIdx = (st.metricIdx + dir + 3) % 3;

            const titleEl = document.getElementById(`title_${key}`);
            if (titleEl) titleEl.textContent = METRICS[st.metricIdx];

            const track    = document.getElementById(`track_${key}`);
            const oldClass = TYPES[oldIdx];
            const newClass = TYPES[st.metricIdx];

            track.querySelectorAll(`.view-section.${oldClass}`).forEach(el => el.classList.remove('active'));
            track.querySelectorAll(`.view-section.${newClass}`).forEach(el => el.classList.add('active'));
        };

        // ═══════════════════════════════════════════════════════
        // 5. RENDER — GAUGE
        // ═══════════════════════════════════════════════════════
        function initChartInstance(id) { updateGauge(id, null, null, 0, 0, 0); }

        // data DUMY
                function toggleDummyBadge(elementId, isDummy) {
            const el = document.getElementById(elementId);
            if (el) el.style.display = isDummy ? 'block' : 'none';
        }

        function updateGauge(canvasId, valId, endId, act, curPlan, dayPlan) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;

            act = act||0; curPlan = curPlan||0; dayPlan = dayPlan||0;

            const pct       = curPlan > 0 ? (act/curPlan)*100 : 0;
            const planPct   = dayPlan > 0 ? Math.min((curPlan/dayPlan)*100, 120) : 0;
            const actualPct = dayPlan > 0 ? Math.min((act/dayPlan)*100, 120) : 0;
            const needlePct = Math.min(pct, 120);

            const wrapper = canvas.parentElement;
            const w = wrapper ? wrapper.clientWidth  : 200;
            const h = wrapper ? wrapper.clientHeight : 130;
            if (w < 10 || h < 10) return;
            canvas.width = w; canvas.height = h;

            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, w, h);

            const safe = Math.min(w, h) * 0.82;
            const sc = safe/180, rO = safe*0.42, rM = safe*0.33, rI = safe*0.24;
            const lw = safe*0.048, cx = w*0.50, cy = h*0.50;
            const SA = Math.PI*0.75, EA = Math.PI*2.25, SPAN = EA-SA;

            function solidArc(radius, pctVal, color) {
                ctx.beginPath(); ctx.arc(cx,cy,radius,SA,EA,false);
                ctx.strokeStyle='rgba(150,150,150,0.25)'; ctx.lineWidth=lw*1.5; ctx.stroke();
                if (pctVal > 0) {
                    ctx.beginPath(); ctx.arc(cx,cy,radius,SA,SA+SPAN*(Math.min(pctVal,120)/120),false);
                    ctx.strokeStyle=color; ctx.lineWidth=lw*1.5; ctx.stroke();
                }
            }

            let bc, bi;
            if (pct<80){bc='rgba(217,4,41,';bi=0.45;}
            else if(pct<85){bc='rgba(255,193,7,';bi=0.4;}
            else{bc='rgba(40,167,69,';bi=0.35;}
            const blR=Math.max(rO*0.28,8);
            const gl=ctx.createRadialGradient(cx,cy,Math.max(0,blR-10),cx,cy,blR+10);
            gl.addColorStop(0,bc+'0)'); gl.addColorStop(0.5,bc+bi+')'); gl.addColorStop(1,bc+'0)');
            ctx.beginPath(); ctx.arc(cx,cy,blR,SA,EA,false);
            ctx.strokeStyle=gl; ctx.lineWidth=20*sc; ctx.stroke();

            solidArc(rO, dayPlan > 0 ? 120 : 0, '#F59E0B');
            solidArc(rM, planPct,   '#22C55E');
            solidArc(rI, actualPct, '#A855F7');

            for(let i=0;i<=10;i++){
                const a=SA+SPAN*(i/10), maj=i%2===0;
                ctx.beginPath();
                ctx.moveTo(cx+(rO-42*sc)*Math.cos(a), cy+(rO-42*sc)*Math.sin(a));
                ctx.lineTo(cx+(rO-(maj?36:39)*sc)*Math.cos(a), cy+(rO-(maj?36:39)*sc)*Math.sin(a));
                const isLM = document.body.classList.contains('light-mode');
                ctx.strokeStyle = isLM ? 'rgba(20,20,40,0.85)' : 'rgba(255,255,255,0.85)';
                ctx.lineWidth=maj?2*sc:1.2*sc; ctx.stroke();
            }

            ctx.textAlign='center'; ctx.textBaseline='middle';
            [0,20,40,60,80,100,120].forEach(n=>{
                const a=SA+SPAN*(n/120);
                ctx.fillStyle = document.body.classList.contains('light-mode') ? 'rgba(20,20,40,0.9)' : 'rgba(255,255,255,0.9)';
                ctx.font=`bold ${Math.max(7,Math.round(8*sc))}px Arial`;
                ctx.fillText(n, cx+(rO-52*sc)*Math.cos(a), cy+(rO-52*sc)*Math.sin(a));
            });

            const na=SA+SPAN*(needlePct/120);
            const nx=cx+rO*0.50*Math.cos(na), ny=cy+rO*0.50*Math.sin(na);
            ctx.beginPath(); ctx.moveTo(cx+2,cy+2); ctx.lineTo(nx+2,ny+2);
            ctx.strokeStyle='rgba(0,0,0,0.4)'; ctx.lineWidth=5*sc; ctx.stroke();
            ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(nx,ny);
            ctx.strokeStyle = document.body.classList.contains('light-mode') ? 'rgba(20,20,40,0.95)' : 'rgba(255,255,255,0.95)';
            ctx.lineWidth=2.5*sc; ctx.lineCap='round'; ctx.stroke();

            ctx.beginPath(); ctx.arc(cx,cy,8*sc,0,Math.PI*2);
            ctx.fillStyle='#ffffff'; ctx.fill();
            ctx.strokeStyle='#14223D'; ctx.lineWidth=2*sc; ctx.stroke();
            ctx.beginPath(); ctx.arc(cx,cy,3*sc,0,Math.PI*2);
            ctx.fillStyle='#14223D'; ctx.fill();

            let lbl = '';
            const parts    = canvasId.split('_');
            const badgeKey = parts[0];
            const badgeIdx = parseInt(parts[1]) - 1;
            if (config[badgeKey]?.labels?.[badgeIdx]) lbl = config[badgeKey].labels[badgeIdx];
            else if (parts[1]) lbl = `Line ${parts[1]}`;

            if (lbl) {
                const fs = Math.max(10, Math.round(sc*14));
                const bw = fs*2.8, bh = fs*1.6, bx = cx-bw/2, by = cy+rO*0.58;
                ctx.save();
                ctx.beginPath();
                const r=4;
                ctx.moveTo(bx+r,by); ctx.lineTo(bx+bw-r,by);
                ctx.quadraticCurveTo(bx+bw,by,bx+bw,by+r);
                ctx.lineTo(bx+bw,by+bh-r);
                ctx.quadraticCurveTo(bx+bw,by+bh,bx+bw-r,by+bh);
                ctx.lineTo(bx+r,by+bh);
                ctx.quadraticCurveTo(bx,by+bh,bx,by+bh-r);
                ctx.lineTo(bx,by+r);
                ctx.quadraticCurveTo(bx,by,bx+r,by);
                ctx.closePath();
                ctx.fillStyle='rgba(255,255,255,0)'; ctx.fill();
                ctx.strokeStyle = document.body.classList.contains('light-mode') ? 'rgba(20,20,40,0.5)' : 'rgba(255,255,255,0.5)';
                ctx.lineWidth=1.5; ctx.stroke();
                ctx.fillStyle = document.body.classList.contains('light-mode') ? '#1a1a2e' : '#ffffff';
                ctx.font=`bold ${fs}px Arial`;
                ctx.textAlign='center'; ctx.textBaseline='middle';
                ctx.fillText(lbl, cx, by+bh/2);
                ctx.restore();
            }

            const pctStr = curPlan > 0 ? ((act/curPlan)*100).toFixed(0) : '0';
            const valEl  = document.getElementById(`val_${canvasId}`);
            const actEl  = document.getElementById(`act_${canvasId}`);
            const spdEl  = document.getElementById(`spd_${canvasId}`);
            const endEl  = document.getElementById(`end_${canvasId}`);
            const sdotEl = document.getElementById(`sdot_${canvasId}`);

            if (valEl)  valEl.textContent  = curPlan.toLocaleString('id-ID');
            if (actEl)  actEl.textContent  = act.toLocaleString('id-ID');
            if (spdEl)  spdEl.textContent  = pctStr;
            if (endEl)  endEl.textContent  = dayPlan.toLocaleString('id-ID');
            if (sdotEl) {
                const c = parseFloat(pctStr)>=85 ? '#22C55E' : parseFloat(pctStr)>=80 ? '#F59E0B' : '#d90429';
                sdotEl.style.background  = c;
                sdotEl.style.borderColor = c;
            }
        }

        // ═══════════════════════════════════════════════════════
        // 6. RENDER — QUALITY (Bar)
        // ═══════════════════════════════════════════════════════
        function updateQuality(key, lineIdx, percentage, defects) {
            const el = document.getElementById(`bar_${key}_${lineIdx}_qual`);
            if (el) {
                el.style.width   = `${percentage}%`;
                el.textContent   = `${percentage}% (${defects} defects)`;
            }
        }

        // ═══════════════════════════════════════════════════════
        // 7. RENDER — LOSS TIME (sama persis WP standalone)
        // ═══════════════════════════════════════════════════════

        // Injeksi loss marker ke dalam timeline-track div
        function drawLossTimeMarkers(trackId, hourlyEvents, totalMinutesInTimeline) {
            const trackEl = document.getElementById(trackId);
            if (!trackEl || !hourlyEvents) return;
            trackEl.querySelectorAll('.loss-marker').forEach(m => m.remove());
            if (totalMinutesInTimeline <= 0) return;

            for (const hour in hourlyEvents) {
                hourlyEvents[hour].forEach(ev => {
                    const startOffsetMin = ((parseInt(hour) - 7) * 60) + ev.startMinute;
                    const leftPct  = (startOffsetMin / totalMinutesInTimeline) * 100;
                    const widthPct = (ev.durationMinutes / totalMinutesInTimeline) * 100;
                    if (leftPct + widthPct <= 100) {
                        const marker = document.createElement('div');
                        marker.className   = 'loss-marker';
                        marker.style.left  = `${leftPct}%`;
                        marker.style.width = `${widthPct}%`;
                        trackEl.appendChild(marker);
                    }
                });
            }
        }

        // Injeksi break marker ke dalam timeline-track div
        function drawBreakTimeMarkers(trackId, breakTimes, totalMinutesInTimeline) {
            const trackEl = document.getElementById(trackId);
            if (!trackEl || !breakTimes) return;
            trackEl.querySelectorAll('.break-marker').forEach(m => m.remove());
            if (totalMinutesInTimeline <= 0) return;

            const timelineStartHour = 7;
            breakTimes.forEach(bt => {
                const startParts = bt.start.split(':').map(Number);
                const endParts   = bt.end.split(':').map(Number);
                const startMin   = startParts[0] * 60 + startParts[1];
                const endMin     = endParts[0]   * 60 + endParts[1];
                const offsetMin  = startMin - (timelineStartHour * 60);
                const durMin     = endMin - startMin;
                if (durMin <= 0) return;

                const leftPct  = (offsetMin / totalMinutesInTimeline) * 100;
                const widthPct = (durMin    / totalMinutesInTimeline) * 100;
                if (leftPct + widthPct <= 100) {
                    const marker = document.createElement('div');
                    marker.className   = 'break-marker';
                    marker.style.left  = `${leftPct}%`;
                    marker.style.width = `${widthPct}%`;
                    trackEl.appendChild(marker);
                }
            });
        }

        // Update timeline — idPrefix = misal "ac_1_loss"
        function updateAssemblyTimeline(idPrefix, lossData) {
            const trackEl    = document.getElementById(`timeline-track-${idPrefix}`);
            const progressEl = document.getElementById(`timeline-progress-${idPrefix}`);
            const hoursEl    = document.getElementById(`timeline-hours-${idPrefix}`);
            const minutesEl  = document.getElementById(`timeline-minutes-${idPrefix}`);
            if (!trackEl || !progressEl || !hoursEl || !minutesEl) return;

            const now        = new Date();
            const startHour  = 7;
            const endOfDay   = 16;
            let dispEndHour  = now.getHours() + 1;
            dispEndHour = Math.max(startHour + 1, dispEndHour);
            dispEndHour = Math.min(dispEndHour, endOfDay);

            const totalMinutes = (dispEndHour - startHour) * 60;

            // Render jam
            hoursEl.innerHTML = '';
            for (let h = startHour; h < dispEndHour; h++) {
                const span = document.createElement('span');
                span.textContent = `${String(h).padStart(2,'0')}.00`;
                hoursEl.appendChild(span);
            }

            minutesEl.innerHTML = '';

            // Break & loss markers
            drawBreakTimeMarkers(`timeline-track-${idPrefix}`, lossData.breakTimes, totalMinutes);
            drawLossTimeMarkers(`timeline-track-${idPrefix}`,  lossData.hourlyEvents, totalMinutes);

            // Progress bar (waktu sekarang)
            const timelineStart   = new Date(now);
            timelineStart.setHours(startHour, 0, 0, 0);
            let elapsedMs         = now - timelineStart;
            const totalMs         = totalMinutes * 60 * 1000;
            elapsedMs = Math.max(0, Math.min(elapsedMs, totalMs));
            progressEl.style.width = `${totalMs > 0 ? (elapsedMs / totalMs) * 100 : 0}%`;

            // Stats
            const wtEl = document.getElementById(`wt_${idPrefix}`);
            const ltEl = document.getElementById(`lt_${idPrefix}`);
            const ldEl = document.getElementById(`ld_${idPrefix}`);
            if (wtEl) wtEl.textContent = lossData.workingTime ?? 0;
            if (ltEl) ltEl.textContent = lossData.lossTime    ?? 0;
            if (ldEl) ldEl.textContent = lossData.loadTime    ?? 0;
        }

        // ═══════════════════════════════════════════════════════
        // 8. DATA FETCHING
        // ═══════════════════════════════════════════════════════
        async function fetchData() {
            try {
                const response = await fetch('?handler=UnifiedData');
                if (!response.ok) return;
                const data = await response.json();

                // ── AC ──
                updateGauge('ac_1_ach', null, null, data.dataAC.lineCU.totalActual, data.dataAC.lineCU.totalPlan, data.dataAC.lineCU.dailyPlan);
                updateGauge('ac_2_ach', null, null, data.dataAC.lineCS.totalActual, data.dataAC.lineCS.totalPlan, data.dataAC.lineCS.dailyPlan);

                updateQuality('ac', 1, data.dataAC.lineCU.qualityRate.toFixed(0), data.dataAC.lineCU.totalDefects);
                updateQuality('ac', 2, data.dataAC.lineCS.qualityRate.toFixed(0), data.dataAC.lineCS.totalDefects);

                if (data.dataAC.lineCU.lossData) updateAssemblyTimeline('ac_1_loss', data.dataAC.lineCU.lossData);
                if (data.dataAC.lineCS.lossData) updateAssemblyTimeline('ac_2_loss', data.dataAC.lineCS.lossData);

                // ── Audio ──
                if (data.dataAudio.total) {
                    const a = data.dataAudio.total;
                    updateGauge('audio_1_ach', null, null, a.totalActual, a.totalPlan, a.dailyPlan);

                    const defects   = a.defectsByCategory || [];
                    const totalDef  = defects.reduce((s, d) => s + d.count, 0);
                    const qualRate  = a.totalActual > 0
                        ? (((a.totalActual - totalDef) / a.totalActual) * 100).toFixed(0)
                        : 100;
                    updateQuality('audio', 1, qualRate, totalDef);

                    if (a.lossData) updateAssemblyTimeline('audio_1_loss', a.lossData);
                }

                // ── Fan ──
                if (data.dataFan?.total) {
                    const fan = data.dataFan.total;
                    updateGauge('fan_1_ach', null, null, fan.totalActual, fan.totalPlan, fan.dailyPlan);
                }

                // ── WP ──
                if (data.dataWP?.total) {
                    const wp       = data.dataWP.total;
                    updateGauge('wp_1_ach', null, null, wp.totalActual, wp.totalPlan, wp.dailyPlan);

                    const wpDef    = wp.defectsByCategory || [];
                    const wpTotDef = wpDef.reduce((s, d) => s + d.count, 0);
                    const wpQual   = wp.totalActual > 0
                        ? (((wp.totalActual - wpTotDef) / wp.totalActual) * 100).toFixed(0)
                        : 100;
                    updateQuality('wp', 1, wpQual, wpTotDef);

                    if (wp.lossData) updateAssemblyTimeline('wp_1_loss', wp.lossData);
                }

                // ── LS ──
                updateGauge('ls_1_ach', null, null, data.dataLS.line1.totalActual, data.dataLS.line1.totalPlan, data.dataLS.line1.dailyPlan);
                updateGauge('ls_2_ach', null, null, data.dataLS.line2.totalActual, data.dataLS.line2.totalPlan, data.dataLS.line2.dailyPlan);
                if (data.dataLS.line1.defectsByCategory) {
                    const d1     = data.dataLS.line1.defectsByCategory;
                    const tot1   = d1.reduce((s, d) => s + d.count, 0);
                    const act1   = data.dataLS.line1.totalActual;
                    const qual1  = act1 > 0 ? (((act1 - tot1) / act1) * 100).toFixed(0) : 100;
                    updateQuality('ls', 1, qual1, tot1);
                }
                if (data.dataLS.line2.defectsByCategory) {
                    const d2     = data.dataLS.line2.defectsByCategory;
                    const tot2   = d2.reduce((s, d) => s + d.count, 0);
                    const act2   = data.dataLS.line2.totalActual;
                    const qual2  = act2 > 0 ? (((act2 - tot2) / act2) * 100).toFixed(0) : 100;
                    updateQuality('ls', 2, qual2, tot2);
                }

                // LS Loss Time — pisah line1 & line2 (bug fix)
                if (data.dataLS.line1.lossData) updateAssemblyTimeline('ls_1_loss', data.dataLS.line1.lossData);
                if (data.dataLS.line2.lossData) updateAssemblyTimeline('ls_2_loss', data.dataLS.line2.lossData);

                // ── Ref ──
                updateGauge('ref_1_ach', null, null, data.dataRef.totalActual, data.dataRef.totalPlan, data.dataRef.dailyPlan);
                updateGauge('ref_2_ach', null, null, 420, 480, 480); // WD dummy — act=420, curPlan=480, dayPlan=480

            } catch (err) { console.error(err); }
        }

        // ═══════════════════════════════════════════════════════
        // 9. THEME TOGGLE
        // ═══════════════════════════════════════════════════════
        function toggleTheme() {
            const body = document.body;
            const btn  = document.getElementById('theme-toggle');
            if (body.classList.contains('light-mode')) {
                body.classList.remove('light-mode');
                btn.textContent = '🌙 Dark';
                localStorage.setItem('theme', 'dark');
            } else {
                body.classList.add('light-mode');
                btn.textContent = '☀️ Light';
                localStorage.setItem('theme', 'light');
            }
            // Redraw semua gauge agar warna jarum ikut update
            Object.keys(config).forEach(key => {
                for (let i = 1; i <= config[key].lines; i++) {
                    const cId   = `${key}_${i}_ach`;
                    const valEl = document.getElementById(`val_${cId}`);
                    const actEl = document.getElementById(`act_${cId}`);
                    const endEl = document.getElementById(`end_${cId}`);
                    if (valEl && actEl && endEl) {
                        const curPlan = parseInt(valEl.textContent.replace(/\./g,'').replace(/,/g,'')) || 0;
                        const act     = parseInt(actEl.textContent.replace(/\./g,'').replace(/,/g,'')) || 0;
                        const dayPlan = parseInt(endEl.textContent.replace(/\./g,'').replace(/,/g,'')) || 0;
                        updateGauge(cId, null, null, act, curPlan, dayPlan);
                    }
                }
            });
        }

        // Restore theme saat load
        if (localStorage.getItem('theme') === 'light') {
            document.body.classList.add('light-mode');
            const btn = document.getElementById('theme-toggle');
            if (btn) btn.textContent = '☀️ Light';
        }

        // ═══════════════════════════════════════════════════════
        // 10. START
        // ═══════════════════════════════════════════════════════
        initDashboard();
        fetchData();
        setInterval(fetchData, 5000);

        // ResizeObserver untuk gauge
        const _gaugeResizeObserver = new ResizeObserver(() => {
            Object.keys(config).forEach(key => {
                for (let i = 1; i <= config[key].lines; i++) {
                    const cId   = `${key}_${i}_ach`;
                    const valEl = document.getElementById(`val_${cId}`);
                    const actEl = document.getElementById(`act_${cId}`);
                    const endEl = document.getElementById(`end_${cId}`);
                    if (valEl && actEl && endEl) {
                        const curPlan = parseInt(valEl.textContent.replace(/\./g,'')) || 0;
                        const act     = parseInt(actEl.textContent.replace(/\./g,'')) || 0;
                        const dayPlan = parseInt(endEl.textContent.replace(/\./g,'')) || 0;
                        updateGauge(cId, null, null, act, curPlan, dayPlan);
                    }
                }
            });
        });
        document.querySelectorAll('.stat-card').forEach(card => {
            _gaugeResizeObserver.observe(card);
        });

        // Clock
        setInterval(() => {
            const now = new Date();
            const el  = document.getElementById('date-display');
            if (el) el.textContent = now.toLocaleDateString('en-GB', {
                weekday: 'long', day: 'numeric', month: 'long',
                year: 'numeric', hour: '2-digit', minute: '2-digit'
            });
        }, 1000);

    </script>

